{
  "name": "MedOS",
  "short_name": "MedOS",
  "description": "A private, local-first medication tracker for daily routines.",
  "display": "standalone",
  "start_url": "./index.html#/",
  "scope": "./",
  "background_color": "#0d1216",
  "theme_color": "#0d1216",
  "icons": [
    {
      "src": "./icons/app-icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "./icons/apple-touch-icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "./icons/icon-maskable.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ]
}
